# Registry Server
DATABASE_URL=postgresql://localhost:5432/aap_registry
REDIS_URL=redis://localhost:6379
IPFS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
GLEIF_API_URL=https://api.gleif.org/api/v1
AAP_SIGNING_KEY=
AAP_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_READS=100

# Ports
REGISTRY_PORT=3001
MAILBOX_PORT=3002
AUDIT_PORT=3003
IDENTITY_PORT=3004
