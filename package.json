{
  "name": "aap",
  "version": "1.0.0",
  "description": "Agent Authentication Protocol — universal communication standard for AI agents",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:registry": "npm run dev --workspace=packages/registry-server",
    "dev:mailbox": "npm run dev --workspace=packages/mailbox-server",
    "dev:audit": "npm run dev --workspace=packages/audit-server",
    "dev:identity": "npm run dev --workspace=packages/identity-service",
    "dev:human-auth": "npm run dev --workspace=packages/human-auth",
    "dev:demo": "npm run dev --workspace=packages/demo-agents",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
